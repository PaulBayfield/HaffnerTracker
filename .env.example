# Copy this file to .env and fill in real values.

ENV=dev

# Discord bot token (Discord Developer Portal -> your app -> Bot -> Reset Token)
TOKEN=

# Your Discord user ID, used to grant owner-only commands
OWNER_ID=

# Optional: NewsAPI.org free API key (https://newsapi.org/register)
# News still works without it via Google News RSS + the press release page.
NEWSAPI_KEY=
